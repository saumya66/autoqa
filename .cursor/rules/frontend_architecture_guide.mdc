## 10. Error Handling

### Limit Error Parser

```ts
// src/lib/limitErrorHandler.ts
import type { LimitExceededError } from '@/types/chat.types'
import { AxiosError } from 'axios'

export function parseLimitError(error: unknown): LimitExceededError | null {
  if (!(error instanceof AxiosError)) return null
  if (error.response?.status !== 403) return null

  const detail = error.response?.data?.detail
  if (
    detail &&
    typeof detail === 'object' &&
    detail.error === 'limit_exceeded' &&
    detail.message &&
    detail.limit_type &&
    typeof detail.current_usage === 'number' &&
    typeof detail.limit === 'number'
  ) {
    return {
      error: 'limit_exceeded',
      message: detail.message,
      limit_type: detail.limit_type,
      current_usage: detail.current_usage,
      limit: detail.limit,
      file_size: detail.file_size,
    }
  }
  return null
}
```

### Usage in Mutations

```ts
const showLimitError = useLimitStore((state) => state.showLimitError)

return useMutation({
  mutationFn: (data) => chatApi.sendMessage(data),
  onError: (error) => {
    const limitError = parseLimitError(error)
    if (limitError) {
      showLimitError(limitError)
    }
  },
})
```

