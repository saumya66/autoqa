### PostHog Utilities

```ts
// src/lib/posthog.ts
import { usePostHog } from 'posthog-js/react'
import posthogDirect from 'posthog-js'
import { useAuthStore } from '@/store/useAuthStore'

/** React hook - auto-includes user_id */
export const usePostHogWithUserId = () => {
  const posthog = usePostHog()
  const userId = useAuthStore((state) => state.user?.user_id)

  return {
    capture: (eventName: string, properties?: Record<string, unknown>) => {
      posthog.capture(eventName, {
        ...properties,
        user_id: userId,
      })
    },
    posthog,
  }
}

/** For non-React (Zustand, etc.) */
export const getUserId = (): string | undefined => {
  const state = useAuthStore.getState()
  return state.user?.user_id
}

export const captureEvent = (eventName: string, properties?: Record<string, unknown>) => {
  const userId = getUserId()
  posthogDirect.capture(eventName, {
    ...properties,
    user_id: userId,
  })
}
```

### Usage in Mutations

```ts
// In useAuthQueries.ts
const posthog = usePostHogWithUserId()

return useMutation({
  mutationFn: (data) => authAPI.login(data),
  onSuccess: (data) => {
    posthog.capture('user_logged_in', {
      user_email: data.user_email,
      name: data.name,
    })
    setAuth(data)
    navigate({ to: '/app' })
  },
})
